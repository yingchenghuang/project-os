PORT=5174
HOST=0.0.0.0

# Required for a public deployment. The browser will show a login prompt.
APP_USERNAME=project-os
APP_PASSWORD=

# Optional durable storage. Use a fine-grained token with Contents read/write
# access to this repository. Keep the token on the server only.
GITHUB_TOKEN=
GITHUB_REPOSITORY=yingchenghuang/project-os
GITHUB_DATA_BRANCH=project-data
GITHUB_DATA_PATH=data/projects.json

# Optional live Notion sync. Keep these on the server only.
# Share the target parent page or database with your Notion integration first.
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_DATABASE_ID=
